{
  "name": "rifaplus-backend",
  "version": "1.0.0",
  "description": "Backend para RifaPlus - Sistema de rifas con WhatsApp",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "NODE_ENV=production node server.js",
    "build": "node ../build/build.js",
    "build:prod": "NODE_ENV=production node ../build/build.js --prod",
    "gzip": "node ../build/gzip.js",
    "e2e": "npx playwright test --project=chromium",
    "migrate": "dotenv_config_path=./.env node -r dotenv/config migrate-smart.js",
    "migrate:baseline": "dotenv_config_path=./.env KNEX_MIGRATIONS_DIR=./db/migrations_baseline node -r dotenv/config ./node_modules/knex/bin/cli.js migrate:latest",
    "migrate:legacy": "dotenv_config_path=./.env node -r dotenv/config ./node_modules/knex/bin/cli.js migrate:latest",
    "migrate:rollback": "dotenv_config_path=./.env node -r dotenv/config ./node_modules/knex/bin/cli.js migrate:rollback",
    "migrate:prod": "dotenv_config_path=./.env NODE_ENV=production node -r dotenv/config migrate-smart.js",
    "seed": "dotenv_config_path=./.env node -r dotenv/config ./node_modules/knex/bin/cli.js seed:run",
    "setup": "chmod +x setup-production.sh && ./setup-production.sh",
    "reset-admin": "node reset-admin.js",
    "pre-deploy": "node pre-deploy-validate.js",
    "validate": "node -r dotenv/config validate-db.js",
    "audit:bd": "node -r dotenv/config audit-bd-supabase.js",
    "apply:index": "node -r dotenv/config apply-partial-index.js",
    "apply:index:oportunidades": "node -r dotenv/config apply-oportunidades-index-optimization.js",
    "cleanup:expiration-log": "node -r dotenv/config drop-unused-expiration-log.js",
    "push:vapid": "node generate-vapid-keys.js",
    "test:integration:multirifa": "dotenv_config_path=./.env node -r dotenv/config --test tests/integration/multirifa.integration.test.js",
    "maintain": "node maintenance.js",
    "maintain:conflict": "node maintenance.js conflict",
    "maintain:opportunities": "node maintenance.js opportunities",
    "maintain:cloudinary": "node maintenance.js cloudinary",
    "sync:config": "node sync-config-json-to-db.js",
    "populate:oportunidades": "node -r dotenv/config populate-oportunidades.js"
  },
  "keywords": [
    "rifa",
    "whatsapp",
    "payment"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^1.20.2",
    "clean-css": "^5.3.3",
    "cloudinary": "^2.7.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "esbuild": "^0.21.5",
    "express": "^4.18.2",
    "express-fileupload": "^1.5.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "imagemin": "^8.0.1",
    "imagemin-jpegtran": "^7.0.0",
    "imagemin-pngquant": "^10.0.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "pg": "^8.17.2",
    "proper-lockfile": "^4.1.2",
    "sanitize-html": "^2.17.0",
    "socket.io": "^4.8.3",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "eslint": "^9.39.2",
    "nodemon": "^2.0.22"
  }
}
